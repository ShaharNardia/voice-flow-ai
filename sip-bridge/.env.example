# Asterisk ARI
ARI_URL=http://127.0.0.1:8088
ARI_USER=voiceflow
ARI_PASS=your_ari_password
ARI_APP=voiceflow-app

# Bridge REST API
PORT=3000
BRIDGE_SECRET=your_bridge_secret_here

# Firebase Cloud Functions base URL
FIREBASE_URL=https://us-central1-voiceflow-ai-202509231639.cloudfunctions.net

# Cloud Run media stream URL
CLOUD_RUN_URL=https://voiceflow-mediastream-900818829902.me-west1.run.app

# Google Cloud TTS (for <Say> verb)
# Either set GOOGLE_APPLICATION_CREDENTIALS path, or paste the key JSON inline
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
TTS_LANGUAGE=he-IL
TTS_VOICE=he-IL-Wavenet-D

# UDP port range for RTP external media (one port per active call)
RTP_PORT_START=7000
RTP_PORT_END=7100

# Asterisk sounds directory — used for <Say> playback before stream starts
# Default: /var/lib/asterisk/sounds  (override if your Asterisk uses a different path)
# AST_SOUNDS_DIR=/var/lib/asterisk/sounds
