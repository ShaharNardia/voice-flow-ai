# UI Test Environment Variables
# Copy this file to .env.test and fill in your test credentials

# Base URL for your application
BASE_URL=http://localhost:3000

# E2E personas (recommended): admin + customer — each gets one Playwright login (storageState).
# chromium-admin + e2e.admin.spec.ts only register when both are set:
E2E_ADMIN_EMAIL=admin-qa@example.com
E2E_ADMIN_PASSWORD=YourAdminPassword123!

# Customer: explicit user creds, or omit and fall back to QA_* below
E2E_USER_EMAIL=customer-qa@example.com
E2E_USER_PASSWORD=YourCustomerPassword123!

# Legacy fallback for customer setup-user when E2E_USER_* omitted
QA_EMAIL=qa-test@example.com
QA_PASSWORD=YourTestPassword123!

# Note: Never commit .env.test with real credentials to version control!
# Saved sessions: tests/ui/.auth/*.json (gitignored)
