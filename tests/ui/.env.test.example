# UI Test Environment Variables
# Copy this file to .env.test and fill in your test credentials

# Base URL for your application (deployed)
BASE_URL=https://voiceflow-ai-202509231639.web.app

# QA Test User Credentials (regular user)
QA_EMAIL=qa-test@example.com
QA_PASSWORD=YourTestPassword123!

# QA Admin User Credentials (must have role: "admin" in Firestore)
QA_ADMIN_EMAIL=qa-admin@example.com
QA_ADMIN_PASSWORD=YourAdminPassword123!

# Firebase Web API Key (from Firebase Console → Project Settings → General)
# Required for API tests that need auth tokens
FIREBASE_API_KEY=your-firebase-web-api-key

# Optional: a specific non-admin uid to test plan overrides without touching real users
# QA_TEST_UID=some-user-uid-here

# Note: Never commit .env.test with real credentials to version control!
