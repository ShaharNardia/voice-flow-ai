# Firebase Functions environment — copy to .env and fill in.
# NOTE: .env is gitignored. Prefer Secret Manager for sensitive keys
# (OPENAI_API_KEY and ELEVENLABS_API_KEY already live there and are bound
# per-function via defineSecret + secrets:[]). The values below are read
# from process.env at runtime.

# ── LLM / AI ────────────────────────────────────────────────────────────
# OPENAI_API_KEY is in Secret Manager — do NOT add it here (a plain-env copy
# shadows the secret and breaks rotation; see the 2026-06-09 incident).

# ── Telephony: Twilio ───────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=AC...              # Twilio Account SID
TWILIO_AUTH_TOKEN=...                 # Twilio Auth Token (TODO: migrate to Secret Manager)
TWILIO_DEFAULT_FROM=+1...             # default outbound caller ID

# ── STT ─────────────────────────────────────────────────────────────────
DEEPGRAM_API_KEY=...                  # Deepgram nova-3/nova-2 (TODO: migrate to Secret Manager)

# ── Cloud Run voice service ─────────────────────────────────────────────
CLOUD_RUN_URL=https://voiceflow-mediastream-myg46khq7q-uc.a.run.app

# ── Flight data (El Al / flights assistant tools) ───────────────────────
AIRLABS_API_KEY=...

# ── SIP bridge (Asterisk) ───────────────────────────────────────────────
SIP_ENCRYPTION_KEY=...                # 64-hex key for encrypting stored SIP creds
SIP_BRIDGE_URL=http://<host>:3000     # Asterisk bridge base URL
SIP_BRIDGE_SECRET=...                 # shared secret for the bridge

# ── Voximplant (telephony partner) ──────────────────────────────────────
# Per-tenant Voximplant creds live on the Company Firestore doc
# (voxAccountId / voxApiKey / voxRuleId / voxCallerId), NOT here.

# Optional Sentry error reporting (leave empty to disable)
SENTRY_DSN=
SENTRY_ENV=production
