{
  "name": "cloud-functions",
  "description": "Firebase Cloud Functions",
  "dependencies": {
    "@deepgram/sdk": "^3.13.0",
    "@google-cloud/logging": "^11.2.2",
    "@google-cloud/secret-manager": "^6.1.3",
    "@google-cloud/text-to-speech": "^5.7.0",
    "@sendgrid/mail": "^8.1.0",
    "axios": "1.8.2",
    "busboy": "^1.6.0",
    "cheerio": "^1.2.0",
    "firebase-admin": "^11.11.0",
    "firebase-functions": "^6.6.0",
    "form-data": "^4.0.5",
    "mammoth": "^1.12.0",
    "pdf-parse": "^1.1.4",
    "qs": "^6.7.0",
    "stripe": "^8.0.1",
    "twilio": "^4.22.0",
    "uuid": "^9.0.1",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "eslint-plugin-promise": "^6.1.1"
  },
  "scripts": {
    "serve": "firebase -P voice-flow-a-i-h66sff emulators:start --only functions",
    "shell": "firebase -P voice-flow-a-i-h66sff functions:shell",
    "start": "npm run shell",
    "logs": "firebase -P voice-flow-a-i-h66sff functions:log",
    "compile": "cp ../../tsconfig.template.json ./tsconfig-compile.json && tsc --project tsconfig-compile.json",
    "lint": "eslint --ext .js ./",
    "test:functions": "npm run lint"
  },
  "engines": {
    "node": "20"
  },
  "private": true
}
