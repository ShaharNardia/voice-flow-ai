# ── Asterisk ARI ──────────────────────────────────────────────────────────────
ASTERISK_HOST=localhost
ASTERISK_ARI_PORT=8088
ASTERISK_ARI_USER=voiceflow
ASTERISK_ARI_PASSWORD=your_ari_password
ASTERISK_ARI_APP=voiceflow-bridge

# Where Asterisk stores recordings (used by AiSession to read WAV files)
ASTERISK_RECORDING_DIR=/var/spool/asterisk/recording

# ── SIP Trunk ──────────────────────────────────────────────────────────────────
SIP_TRUNK_NAME=partner-trunk
DEFAULT_CALLER_ID=+972501234567

# ── Firebase ───────────────────────────────────────────────────────────────────
FIREBASE_PROJECT_ID=voiceflow-ai-202509231639
FIREBASE_SERVICE_ACCOUNT_PATH=./service-account.json

# ── Bridge server ──────────────────────────────────────────────────────────────
BRIDGE_PORT=3000
BRIDGE_SECRET=your_secret_key_here

# ── AI mode (set to "false" for legacy DTMF-only mode) ────────────────────────
AI_MODE=true

# ── STT — Deepgram ─────────────────────────────────────────────────────────────
DEEPGRAM_API_KEY=your_deepgram_api_key

# ── LLM — OpenAI ──────────────────────────────────────────────────────────────
OPENAI_API_KEY=your_openai_api_key
LLM_MODEL=gpt-4o-mini

# ── Conversation tuning ────────────────────────────────────────────────────────
MAX_CONVERSATION_TURNS=10
# Seconds of silence before Asterisk stops recording (VAD)
MAX_SILENCE_SECONDS=3

# ── TTS ────────────────────────────────────────────────────────────────────────
# Options: google (recommended), festival, espeak, external
TTS_PROVIDER=google
TTS_LANGUAGE=he-IL
TTS_VOICE=he-IL-Wavenet-D

# Google TTS credentials (when TTS_PROVIDER=google)
GOOGLE_APPLICATION_CREDENTIALS=./google-tts-credentials.json

# Audio output dir — must be accessible by Asterisk as a sound path
AUDIO_DIR=/var/lib/asterisk/sounds/voiceflow
