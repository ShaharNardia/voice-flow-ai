rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper functions ──────────────────────────────────────────
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/user/$(request.auth.uid)).data;
    }

    function isAdmin() {
      return isAuthenticated() && getUserData().role == 'admin';
    }

    function belongsToCompany(companyId) {
      return isAuthenticated() &&
        getUserData().company != null &&
        getUserData().company == /databases/$(database)/documents/Company/$(companyId);
    }

    // Validate that write doesn't contain script tags (basic XSS prevention)
    function noScriptTags(value) {
      return !(value is string) || (!value.matches('.*<script.*') && !value.matches('.*onerror.*=.*'));
    }

    // ── User collection ───────────────────────────────────────────
    // Users can only create their own document.
    // Users can read/write their own document.
    // Admins can read any user document.
    match /user/{userId} {
      allow create: if isOwner(userId);
      allow read:   if isOwner(userId) || isAdmin();
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if false; // Users cannot be deleted from client
    }

    // ── Company collection ────────────────────────────────────────
    // Only users belonging to a company can read/write it.
    // Admins have full access.
    match /Company/{companyId} {
      allow create: if isAuthenticated(); // Created during onboarding
      allow read:   if belongsToCompany(companyId) || isAdmin();
      allow update: if belongsToCompany(companyId) || isAdmin();
      allow delete: if isAdmin();
    }

    // ── Jobs collection ───────────────────────────────────────────
    // Only company members can access their jobs.
    match /Jobs/{jobId} {
      allow create: if isAuthenticated();
      allow read:   if isAuthenticated() &&
                       (resource.data.createdBy == request.auth.uid ||
                        isAdmin());
      allow update: if isAuthenticated() &&
                       (resource.data.createdBy == request.auth.uid ||
                        isAdmin());
      allow delete: if isAdmin();
    }

    // ── Lead collection ───────────────────────────────────────────
    // Company members can read/write leads belonging to their company.
    match /Lead/{leadId} {
      allow create: if isAuthenticated();
      allow read:   if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if isAdmin();
    }

    // ── Call / CallLogs / CallSessions ─────────────────────────────
    match /Call/{callId} {
      allow create: if isAuthenticated();
      allow read:   if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if false;
    }

    match /CallLogs/{logId} {
      allow create: if isAuthenticated();
      allow read:   if isAuthenticated();
      allow update: if false;
      allow delete: if false;
    }

    match /CallSessions/{sessionId} {
      allow create: if isAuthenticated();
      allow read:   if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if false;
    }

    // ── Assistants collection ─────────────────────────────────────
    match /assistants/{assistantId} {
      allow create: if isAuthenticated();
      allow read:   if isAuthenticated();
      allow update: if isAuthenticated() &&
                       (resource.data.ownerId == request.auth.uid ||
                        isAdmin());
      allow delete: if isAuthenticated() &&
                       (resource.data.ownerId == request.auth.uid ||
                        isAdmin());
    }

    // ── Scenarios collection ──────────────────────────────────────
    match /scenarios/{scenarioId} {
      allow create: if isAuthenticated();
      allow read:   if isAuthenticated();
      allow update: if isAuthenticated() &&
                       (resource.data.ownerId == request.auth.uid ||
                        isAdmin());
      allow delete: if isAuthenticated() &&
                       (resource.data.ownerId == request.auth.uid ||
                        isAdmin());
    }

    // ── Technician collection ─────────────────────────────────────
    match /Technician/{techId} {
      allow create: if isAdmin();
      allow read:   if isAuthenticated();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ── Admin collection ──────────────────────────────────────────
    match /admin/{document} {
      allow create: if false;
      allow read:   if isAdmin();
      allow write:  if false;
      allow delete: if false;
    }

    // ── Stripe idempotency tracking ───────────────────────────────
    match /ProcessedStripeEvents/{eventId} {
      allow read:   if false;
      allow write:  if false; // Only server-side (admin SDK) writes
      allow delete: if false;
    }

    // ── Clients collection ────────────────────────────────────────
    match /Clients/{clientId} {
      allow create: if isAuthenticated();
      allow read:   if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if isAdmin();
    }

    // ── TransferLogs collection ───────────────────────────────────
    match /TransferLogs/{logId} {
      allow create: if isAuthenticated();
      allow read:   if isAuthenticated();
      allow update: if false;
      allow delete: if false;
    }

    // ── leads collection (saas-frontend, lowercase) ───────────────
    match /leads/{leadId} {
      allow create: if isAuthenticated();
      allow read:   if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if isAdmin();
    }

    // ── campaigns collection ───────────────────────────────────────
    match /campaigns/{campaignId} {
      allow create: if isAuthenticated();
      allow read:   if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if isAuthenticated();
    }

    // ── call_sessions collection (saas-frontend, lowercase) ───────
    match /call_sessions/{sessionId} {
      allow create: if isAuthenticated();
      allow read:   if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if false;
    }

    // ── phone_numbers collection ───────────────────────────────────
    match /phone_numbers/{phoneId} {
      allow create: if isAuthenticated();
      allow read:   if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if isAdmin();
    }

    // ── knowledge_sources subcollection (per assistant) ────────────
    match /assistants/{assistantId}/knowledge_sources/{sourceId} {
      allow create: if isAuthenticated();
      allow read:   if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if isAuthenticated();
    }

    // ── SystemSettings (admin-only config) ────────────────────────
    match /SystemSettings/{docId} {
      allow read:   if isAdmin();
      allow write:  if isAdmin();
    }

    // ── Deny everything else by default ───────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
