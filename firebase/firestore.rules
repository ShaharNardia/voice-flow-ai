rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper functions ──────────────────────────────────────────
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/user/$(request.auth.uid)).data;
    }

    function isAdmin() {
      return isAuthenticated() && (
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin') ||
        (exists(/databases/$(database)/documents/user/$(request.auth.uid)) &&
         get(/databases/$(database)/documents/user/$(request.auth.uid)).data.role == 'admin')
      );
    }

    function belongsToCompany(companyId) {
      return isAuthenticated() &&
        getUserData().company != null &&
        getUserData().company == /databases/$(database)/documents/Company/$(companyId);
    }

    // Validate that write doesn't contain script tags (basic XSS prevention)
    function noScriptTags(value) {
      return !(value is string) || (!value.matches('.*<script.*') && !value.matches('.*onerror.*=.*'));
    }

    // ── User collection (legacy singular) ────────────────────────
    match /user/{userId} {
      allow create: if isOwner(userId);
      allow read:   if isOwner(userId) || isAdmin();
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if false;
    }

    // ── Users collection (new plural — multi-tenant) ──────────────
    match /users/{userId} {
      allow create: if isAuthenticated() && request.auth.uid == userId;
      allow read:   if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow update: if isAdmin();
      allow delete: if false;
    }

    // ── Company collection ────────────────────────────────────────
    // Only users belonging to a company can read/write it.
    // Admins have full access.
    match /Company/{companyId} {
      allow create: if isAuthenticated(); // Created during onboarding
      allow read:   if belongsToCompany(companyId) || isAdmin();
      allow update: if belongsToCompany(companyId) || isAdmin();
      allow delete: if isAdmin();
    }

    // ── Jobs collection ───────────────────────────────────────────
    // Only company members can access their jobs.
    match /Jobs/{jobId} {
      allow create: if isAuthenticated();
      allow read:   if isAuthenticated() &&
                       (resource.data.createdBy == request.auth.uid ||
                        isAdmin());
      allow update: if isAuthenticated() &&
                       (resource.data.createdBy == request.auth.uid ||
                        isAdmin());
      allow delete: if isAdmin();
    }

    // ── Lead collection (both legacy "Lead" and new "leads") ──────
    match /Lead/{leadId} {
      allow create: if isAuthenticated();
      allow read:   if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if isAdmin();
    }
    match /leads/{leadId} {
      allow create: if isAuthenticated();
      allow read:   if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if isAuthenticated();
    }

    // ── Campaigns collection ──────────────────────────────────────
    match /campaigns/{campaignId} {
      allow create: if isAuthenticated();
      allow read:   if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if isAuthenticated();
    }

    // ── Call / CallLogs / CallSessions ─────────────────────────────
    match /Call/{callId} {
      allow create: if isAuthenticated();
      allow read:   if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if false;
    }

    match /CallLogs/{logId} {
      allow create: if isAuthenticated();
      allow read:   if isAuthenticated();
      allow update: if false;
      allow delete: if false;
    }

    match /CallSessions/{sessionId} {
      allow create: if isAuthenticated();
      allow read:   if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if false;
    }

    // ── call_sessions collection (lowercase — actual backend collection name) ─
    match /call_sessions/{sessionId} {
      allow create: if isAuthenticated();
      allow read:   if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if false;
    }

    // ── Assistants collection ─────────────────────────────────────
    match /assistants/{assistantId} {
      allow create: if isAuthenticated();
      allow read:   if isAuthenticated() &&
                       (resource.data.ownerId == null ||
                        resource.data.ownerId == request.auth.uid ||
                        isAdmin());
      allow update: if isAuthenticated() &&
                       (resource.data.ownerId == null ||
                        resource.data.ownerId == request.auth.uid ||
                        isAdmin());
      allow delete: if isAuthenticated() &&
                       (resource.data.ownerId == null ||
                        resource.data.ownerId == request.auth.uid ||
                        isAdmin());
    }

    // ── Scenarios collection ──────────────────────────────────────
    match /scenarios/{scenarioId} {
      allow create: if isAuthenticated();
      allow read:   if isAuthenticated() &&
                       (resource.data.ownerId == null ||
                        resource.data.ownerId == request.auth.uid ||
                        isAdmin());
      allow update: if isAuthenticated() &&
                       (resource.data.ownerId == null ||
                        resource.data.ownerId == request.auth.uid ||
                        isAdmin());
      allow delete: if isAuthenticated() &&
                       (resource.data.ownerId == null ||
                        resource.data.ownerId == request.auth.uid ||
                        isAdmin());
    }

    // ── phone_numbers collection ──────────────────────────────────
    match /phone_numbers/{numberId} {
      allow create: if isAuthenticated();
      allow read:   if isAuthenticated() &&
                       (resource.data.userId == null ||
                        resource.data.userId == request.auth.uid ||
                        isAdmin());
      allow update: if isAuthenticated() &&
                       (resource.data.userId == null ||
                        resource.data.userId == request.auth.uid ||
                        isAdmin());
      allow delete: if isAuthenticated() &&
                       (resource.data.userId == null ||
                        resource.data.userId == request.auth.uid ||
                        isAdmin());
    }

    // ── Technician collection ─────────────────────────────────────
    match /Technician/{techId} {
      allow create: if isAdmin();
      allow read:   if isAuthenticated();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ── Admin collection ──────────────────────────────────────────
    match /admin/{document} {
      allow create: if false;
      allow read:   if isAdmin();
      allow write:  if false;
      allow delete: if false;
    }

    // ── Stripe idempotency tracking ───────────────────────────────
    match /ProcessedStripeEvents/{eventId} {
      allow read:   if false;
      allow write:  if false; // Only server-side (admin SDK) writes
      allow delete: if false;
    }

    // ── Clients collection ────────────────────────────────────────
    match /Clients/{clientId} {
      allow create: if isAuthenticated();
      allow read:   if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if isAdmin();
    }

    // ── TransferLogs collection ───────────────────────────────────
    match /TransferLogs/{logId} {
      allow create: if isAuthenticated();
      allow read:   if isAuthenticated();
      allow update: if false;
      allow delete: if false;
    }

    // ── Config collection (admin-managed settings) ────────────────
    match /config/{document} {
      allow read:  if isAdmin();
      allow write: if isAdmin();
    }

    // ── call_feedback collection (post-call quality ratings) ──────
    match /call_feedback/{feedbackId} {
      allow create: if isAuthenticated();
      allow read:   if isAuthenticated();
      allow update: if false;
      allow delete: if isAdmin();
    }

    // ── knowledge_chunks (RAG chunks) — server-side only ──────────
    match /knowledge_chunks/{chunkId} {
      allow read:   if isAuthenticated();
      allow write:  if false;
    }

    // ── Deny everything else by default ───────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
